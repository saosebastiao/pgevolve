  "constraint:app.sessions.sessions_pkey" -> "table:app.sessions" [style=solid];
  "function:app.fn_a()" -> "schema:app" [style=solid];
  "function:app.fn_b()" -> "schema:app" [style=solid];
  "trigger:app.trg_sessions_hook" -> "table:app.sessions" [style=solid];
  "trigger:app.trg_sessions_hook" -> "function:app.fn_b()" [style=solid];
