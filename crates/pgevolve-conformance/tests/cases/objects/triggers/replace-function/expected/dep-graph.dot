  node [shape=box, fontname=Helvetica];
  "constraint:app.sessions.sessions_pkey";
  "function:app.fn_a()";
  "function:app.fn_b()";
  "schema:app";
  "table:app.sessions";
  "trigger:app.trg_sessions_hook";
